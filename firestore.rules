rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===================================
    // CONTEÚDO DO SITE (leitura pública, escrita admin)
    // ===================================

    match /content/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pacotes/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /blogPosts/{documentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      // Permite atualizar apenas views sem autenticação
      allow update: if request.auth != null 
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'updatedAt']));
    }

    match /categorias/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /banners/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bannersLojinha/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bannersTurismo/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /linkInBio/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /images/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /whatsappConfig/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ===================================
    // FORMULÁRIOS PÚBLICOS (create público, gestão admin)
    // ===================================

    match /avaliacoes/{documentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /listas/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reservas/{documentId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /newsletter/{documentId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /contatos/{documentId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ===================================
    // DADOS SENSÍVEIS (requer autenticação)
    // ===================================

    match /viagens/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /produtos/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /campaigns/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /adminUsers/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /motoristas/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /analytics/{documentId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // ===================================
    // FALLBACK: nega tudo não especificado
    // ===================================

    match /{collection}/{documentId} {
      allow read, write: if false;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /pacotes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /produtos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
