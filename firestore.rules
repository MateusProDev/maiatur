rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== CONTEÚDO DO SITE (público para leitura) ====================
    
    // Conteúdo gerenciável (serviços, diferenciais, boxes, carrossel, etc.)
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Configurações do site (header, footer, whatsapp, etc.)
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pacotes de viagem
    match /pacotes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Blog posts
    match /blog/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categorias
    match /categorias/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Banners
    match /banners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Google Reviews
    match /googleReviews/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Link in Bio
    match /linkInBio/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==================== RESERVAS E PAGAMENTOS ====================

    // Reservas - leitura para usuários autenticados, escrita via webhook ou admin
    match /reservas/{docId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ==================== USUÁRIOS ====================

    // Users: qualquer autenticado pode ler, só o próprio pode escrever
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Admin users list
    match /adminUsers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ==================== MOTORISTAS ====================

    match /motoristas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ==================== ANALYTICS ====================

    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // ==================== NEWSLETTER ====================

    match /newsletter/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ==================== CONTATO ====================

    match /contatos/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Fallback: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
